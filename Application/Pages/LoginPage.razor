@page "/"
@page "/login"

@layout LoginLayout

@inject NavigationManager NavigationManager
@inject DiscogsClient DiscogsClient
@inject LocalStorageService LocalStorageService
@inject ISnackbar Snackbar

<MudOverlay Visible="IsBusy" DarkBackground="true">
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
</MudOverlay>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="d-flex justify-center mt-12 ">
    <MudCard Class="pa-6 component" Style="width: 100%; ">
        <MudText Typo="Typo.h5" Class="mb-4">
            @Messages.WelcomeToDiscogg
        </MudText>
        <div class="d-flex flex-column">
            <MudTextField @bind-Value="Token"
                          Label="@(Messages.ApiToken)"
                          Variant="Variant.Outlined"
                          InputType="@(ShowPassword? InputType.Text: InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(ShowPassword? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="TogglePasswordVisibility"
                          IconSize="Size.Medium" />

            <MudLink Typo="Typo.caption" Target="_blank"
                     Href="https://www.discogs.com/settings/developers"
                     Class="ml-auto mt-1">
                @Messages.WhereTokenFrom
            </MudLink>
        </div>
        <MudCheckBox T="bool" Label=@Messages.RememberToken @bind-Value="this.RememberMe" Color="Color.Primary" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoginAsync" FullWidth="true">
            @Messages.Connect
        </MudButton>
    </MudCard>
</MudContainer>

@code {
    /// <summary>
    /// Local storage key for the remember‑token flag.
    /// </summary>
    private const string REMEMBER_TOKEN_KEY = "remember-token";

    /// <summary>
    /// Local storage key for the stored API token.
    /// </summary>
    private const string TOKEN_KEY = "token";

    /// <summary>
    /// Truthy value indicating the token should be remembered.
    /// </summary>
    private const string REMEMBER_TOKEN_TRUTHY = "T";

    /// <summary>
    /// Gets or sets the API token entered by the user.
    /// </summary>
    private string? Token { get; set; }

    /// <summary>
    /// Gets or sets whether the token should be persisted.
    /// </summary>
    private bool RememberMe { get; set; }

    /// <summary>
    /// Gets or sets whether the password is visible.
    /// </summary>
    private bool ShowPassword { get; set; }

    /// <summary>
    /// Gets or sets whether a request is in progress.
    /// </summary>
    private bool IsBusy { get; set; }

    /// <summary>
    /// Loads persisted token preference on initialization.
    /// </summary>
    protected async override Task OnInitializedAsync()
    {
        this.RememberMe = await this.LocalStorageService.GetAsync(REMEMBER_TOKEN_KEY) == REMEMBER_TOKEN_TRUTHY;

        if (this.RememberMe && await this.LocalStorageService.GetDecryptedAsync(TOKEN_KEY) is string token)
        {
            this.Token = token;
        }

        this.DiscogsClient.OnHttpRequestStarting += (sender, args) =>
        {
            this.IsBusy = true;
        };

        this.DiscogsClient.OnHttpRequestCompleted += (sender, args) =>
        {
            this.IsBusy = false;
        };

        this.DiscogsClient.OnError += (sender, args) =>
        {
            this.Snackbar.Add(args.ErrorMessage, Severity.Error);
            this.IsBusy = false;
        };
    }

    /// <summary>
    /// Toggles password visibility.
    /// </summary>
    private void TogglePasswordVisibility()
    {
        this.ShowPassword = !this.ShowPassword;
    }

    /// <summary>
    /// Authenticates the user with the provided API token.
    /// </summary>
    private async Task LoginAsync()
    {
       /* if (await this.AuthenticationService.AuthenticateAsync(this.Token ?? string.Empty) is OAuth oAuth)
        {
