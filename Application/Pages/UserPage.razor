@page "/user/{userName}"

@inject NavigationManager Nav
@inject DiscogsClient DiscogsClient

<PageTitle>@userName</PageTitle>

<MudGrid>
    @if (isLoading)
    {
        <MudItem xs="12">
            <MudProgressLinear Indeterminate />
        </MudItem>
    }
    else if (user is null)
    {
        <MudItem xs="12">
            <MudAlert Severity="Severity.Warning">User not found.</MudAlert>
        </MudItem>
    }
    else
    {
        <!-- Left Sidebar - Avatar & Basic Info -->
        <MudItem xs="12" md="4" lg="3">
            <MudCard>
                <MudCardContent Class="d-flex flex-column align-center">
                    <MudAvatar Size="Size.Large" Class="mb-3">
                        <MudImage Src="@user.AvatarUrl" Alt="avatar" />
                    </MudAvatar>
                    
                    @if (!string.IsNullOrWhiteSpace(user.Name))
                    {
                        <MudText Typo="Typo.h6">@user.Name</MudText>
                    }
                    
                    <MudText Typo="Typo.caption" Color="Color.Default">
                        Member since @user.RegisteredDate
                    </MudText>

                    @if (!string.IsNullOrWhiteSpace(user.Location))
                    {
                        <MudText Typo="Typo.body2" Class="mt-2">
                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" /> @user.Location
                        </MudText>
                    }

                    @if (!string.IsNullOrWhiteSpace(user.HomePage))
                    {
                        <MudLink Href="@user.HomePage" Target="_blank" Class="mt-2">
                            @user.HomePage
                        </MudLink>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Main Content Area -->
        <MudItem xs="12" md="8" lg="9">
            <MudText Typo="Typo.h4" Class="mb-4">@user.UserName</MudText>

            <!-- Collection Carousel -->
            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">Collection</MudText>
                
                <div class="carousel-container">
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Default" 
                               OnClick="PrevItem"
                               Class="carousel-btn">
                        <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" />
                    </MudButton>

                    <div class="carousel-items">
                        @foreach (var item in visibleItems)
                        {
                            <div class="carousel-item">
                                <MudCard>
                                    <MudCardMedia Image="@item.BasicInformation?.Thumb" Height="150" />
                                    <MudCardContent Class="pa-2">
                                        <MudText Typo="Typo.body2" Class="truncate-text">
                                            @item.BasicInformation?.Title
                                        </MudText>
                                    </MudCardContent>
                                </MudCard>
                            </div>
                        }
                    </div>

                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Default" 
                               OnClick="NextItem"
                               Class="carousel-btn">
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" />
                    </MudButton>
                </div>
            </MudPaper>

            <!-- Stats Section -->
            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">Stats</MudText>
                
                <MudSimpleTable Dense>
                    <tbody>
                        <tr>
                            <td>Total items</td>
                            <td>@totalItems</td>
                        </tr>
                        <tr>
                            <td>Sum of lowest prices</td>
                            <td>@sumLowestPrice €</td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudPaper>

            <!-- German Placeholder Note -->
            <MudPaper Class="pa-4 mb-4" Color="Color.Info">
                <MudText Typo="Typo.body2">
                    <b>Hinweis:</b> Weitere Funktionen werden in Kürze verfügbar sein.
                </MudText>
            </MudPaper>
        </MudItem>

        <!-- Footer -->
        <MudItem xs="12">
            <MudDivider Class="mb-2" />
            <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary">
                © 2024 Discogg. Alle Rechte vorbehalten.
            </MudText>
        </MudItem>
    }
</MudGrid>

<style>
    .carousel-container {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .carousel-items {
        display: flex;
        gap: 16px;
        flex: 1;
        justify-content: center;
    }

    .carousel-item {
        flex: 0 0 calc(33.333% - 11px);
        max-width: 200px;
    }

    .carousel-btn {
        flex-shrink: 0;
    }

    .truncate-text {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 180px;
    }
</style>

